html
  head
    title {title}
    style static/style.css
  body
    div.header
      h1 {title}
      p.subtitle Reactive demo with Sucuri

    div.layout
      div.sidebar
        h2 Update price
        div.form
          label Product:
          input(type="text" id="name" value="Widget A")
          label New price:
          input(type="number" id="price" value="0" step="0.01")
          button(onclick="updatePrice()") Apply

        div.form
          label Add product:
          input(type="text" id="newName" placeholder="Product name")
          input(type="number" id="newPrice" placeholder="Price" step="0.01")
          button(onclick="addProduct()") Add

      div.main
        watch products
          <for p in products>
          div.card
            span.name {p.name}
            span.price $ {p.price}
          <endfor>

        watch cart
          div.cart-summary
            h3 Cart
            p Items: {cart.count}
            p Total: $ {cart.total}

    script static/app.js
